{
  "permissions": {
    "allow": [
      "Bash(go *)",
      "Bash(findstr *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(npx chrome-devtools-mcp *)",
      "Bash(npx @anthropic-ai/chrome-devtools-mcp *)",
      "Bash(npm run *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(curl *)",
      "Bash(taskkill *)",
      "Bash(timeout *)",
      "Bash(tasklist)",
      "Bash(type *)"
    ]
  },
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "chrome-devtools-mcp@latest"
      ]
    }
  },
  "$version": 3
}