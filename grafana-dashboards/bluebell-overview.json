    {
      "id": 5,
      "title": "Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(bluebell_errors_total[$__rate_interval]))",
