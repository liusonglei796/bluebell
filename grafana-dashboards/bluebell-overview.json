        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["max", "mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 12,
      "title": "Go Runtime - Goroutines & Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 12 },
      "datasource": { "type": "prometheus" },
      "targets": [
        {
          "expr": "go_goroutine_count",
          "legendFormat": "Goroutines"
        },
        {
          "expr": "go_memory_used_bytes",
          "legendFormat": "Memory Used"
        },
        {
          "expr": "go_memory_gc_goal_bytes",
          "legendFormat": "GC Goal"
        },
        {
          "expr": "go_memory_allocated_bytes_total",
          "legendFormat": "Total Allocated"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "auto",
            "spanNulls": false,
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Memory Used" },
            "properties": [
              { "id": "unit", "value": "bytes" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "GC Goal" },
            "properties": [
              { "id": "unit", "value": "bytes" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Total Allocated" },
            "properties": [
              { "id": "unit", "value": "bytes" }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["max", "mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
